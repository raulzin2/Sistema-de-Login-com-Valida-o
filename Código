# ==========================================
# Sistema de Login com Validação
# Desenvolvido para terminal (CLI)
# ==========================================

def exibir_menu():
    """Exibe as opções principais do sistema."""
    print("\n" + "=" * 40)
    print("        SISTEMA DE AUTENTICAÇÃO")
    print("=" * 40)
    print("[1] - Cadastrar novo usuário")
    print("[2] - Fazer Login")
    print("[3] - Sair do sistema")
    print("=" * 40)

def cadastrar_usuario(usuarios):
    """Gerencia o cadastro de novos usuários no sistema."""
    print("\n--- Cadastro de Usuário ---")
    nome_usuario = input("Digite um nome de usuário: ").strip()

    # Validação 1: Verificar se o usuário já existe
    if nome_usuario in usuarios:
        print("Erro: O usuário '{}' já está cadastrado.".format(nome_usuario))
        return

    # Validação 2: Impedir nome de usuário vazio
    if not nome_usuario:
        print("Erro: O nome de usuário não pode ser vazio.")
        return

    senha = input("Digite uma senha: ").strip()

    # Validação 3: Impedir senha vazia
    if not senha:
        print("Erro: A senha não pode ser vazia.")
        return

    # Armazenando no dicionário com a estrutura exigida
    usuarios[nome_usuario] = {
        "senha": senha,
        "tentativas": 0,
        "bloqueado": False
    }
    
    print("Sucesso: Usuário '{}' cadastrado com sucesso!".format(nome_usuario))

def validar_senha(usuarios, nome_usuario, senha_digitada):
    """
    Valida a senha do usuário e controla as tentativas.
    Retorna True se a senha estiver correta, False caso contrário.
    """
    dados_usuario = usuarios[nome_usuario]

    if dados_usuario["senha"] == senha_digitada:
        # Se acertar a senha, zera as tentativas falhas
        dados_usuario["tentativas"] = 0
        return True
    else:
        # Se errar, incrementa o contador de tentativas
        dados_usuario["tentativas"] += 1
        
        # Se atingir 3 tentativas, bloqueia a conta
        if dados_usuario["tentativas"] >= 3:
            dados_usuario["bloqueado"] = True
            
        return False

def realizar_login(usuarios):
    """Gerencia o fluxo de login e exibição de mensagens de bloqueio/erro."""
    print("\n--- Login ---")
    nome_usuario = input("Usuário: ").strip()

    # Verifica se o usuário existe no "banco de dados" (dicionário)
    if nome_usuario not in usuarios:
        print("Erro: Usuário não encontrado no sistema.")
        return

    # Verifica se a conta já está bloqueada antes mesmo de pedir a senha
    if usuarios[nome_usuario]["bloqueado"]:
        print("Acesso Negado: A conta '{}' está bloqueada por excesso de tentativas.".format(nome_usuario))
        return

    senha_digitada = input("Senha: ").strip()

    # Chama a função de validação de senha
    login_sucesso = validar_senha(usuarios, nome_usuario, senha_digitada)

    if login_sucesso:
        print("\nSucesso: Login realizado! Bem-vindo(a), {}!".format(nome_usuario))
    else:
        # Calcula quantas tentativas restam para informar ao usuário
        tentativas_restantes = 3 - usuarios[nome_usuario]["tentativas"]
        
        if usuarios[nome_usuario]["bloqueado"]:
            print("Alerta de Segurança: Senha incorreta 3 vezes. Sua conta foi BLOQUEADA.")
        else:
            print("Erro: Senha incorreta. Você tem mais {} tentativa(s).".format(tentativas_restantes))

def main():
    """Função principal que controla o loop do sistema."""
    # Dicionário que atuará como nosso banco de dados em memória
    usuarios = {}

    while True:
        exibir_menu()
        opcao = input("Escolha uma opção (1-3): ").strip()

        if opcao == "1":
            cadastrar_usuario(usuarios)
        elif opcao == "2":
            realizar_login(usuarios)
        elif opcao == "3":
            print("\nEncerrando o sistema de autenticação. Até logo!")
            break
        else:
            print("\nErro: Opção inválida. Digite 1, 2 ou 3.")

# Executa a aplicação
if __name__ == "__main__":
    main()
